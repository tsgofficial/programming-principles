node(a).
node(b).
node(c).
node(d).
node(e).

edge(a, b).
edge(b, c).
edge(c, d).
edge(d, e).
edge(a, d).

connected(X, Y) :- edge(X, Y).

reachable(X, Y) :- connected(X, Y).
reachable(X, Y) :- connected(X, Z), reachable(Z, Y).

?- edge(a, b).
?- connected(a, b).
?- connected(b, a).
?- reachable(a, c).
?- reachable(a, e).
?- reachable(b, d).
?- reachable(e, a).
