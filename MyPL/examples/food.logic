edible(X) :- fruit(X).
edible(X) :- vegetable(X).

good_for_health(X) :- healthy(X).

?- fruit(apple).
?- vegetable(carrot).
?- edible(apple).
?- edible(carrot).
?- edible(pizza).
?- good_for_health(apple).
?- good_for_health(carrot).
