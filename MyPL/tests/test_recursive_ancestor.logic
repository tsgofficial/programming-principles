# Test 3: Recursive rule (ancestor)
parent(tom, bob).
parent(tom, liz).
parent(bob, ann).
parent(bob, pat).
parent(pat, jim).

ancestor(X, Y) :- parent(X, Y).
ancestor(X, Y) :- parent(X, Z), ancestor(Z, Y).

?- ancestor(tom, bob).
?- ancestor(tom, ann).
?- ancestor(tom, pat).
?- ancestor(tom, jim).
?- ancestor(bob, jim).
?- ancestor(liz, ann).
